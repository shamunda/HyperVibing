#!/bin/sh
# ──────────────────────────────────────────────────────────────────
# Watchdog — Claude Code Supervisor Agent
# Author: Dennis "Shamunda" Ross
# Date:   March 2026
# MCP server that monitors and supervises Claude Code sessions.
# ──────────────────────────────────────────────────────────────────
# ── Watchdog pre-commit hook: Secret & Sensitive Data Scanner ──
# Blocks commits that contain API keys, tokens, passwords, private keys,
# connection strings, or other secrets.
# Uses grep -E (POSIX extended regex) for cross-platform compatibility.

echo "Watchdog: Scanning staged files for secrets..."

# Get list of staged files (excludes deleted files)
STAGED=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED" ]; then
    exit 0
fi

FOUND=0

# Files/paths to always skip
SKIP_PATTERNS="\.(lock|min\.js|min\.css|dll|exe|png|jpg|gif|ico|woff|woff2)$"

for file in $STAGED; do
    # Skip binary/minified files
    echo "$file" | grep -qE "$SKIP_PATTERNS" && continue

    # Skip the hook files themselves
    echo "$file" | grep -qE "^hooks/pre-commit$|^hooks/pre-push$" && continue

    # Get staged content (not working directory)
    CONTENT=$(git show ":$file" 2>/dev/null) || continue

    # AWS Access Key
    echo "$CONTENT" | grep -qE "AKIA[0-9A-Z]{16}" && {
        echo "  BLOCKED: AWS Access Key found in $file"
        FOUND=$((FOUND + 1))
    }

    # GitHub Token
    echo "$CONTENT" | grep -qE "gh[pousr]_[A-Za-z0-9_]{36,}" && {
        echo "  BLOCKED: GitHub Token found in $file"
        FOUND=$((FOUND + 1))
    }

    # Anthropic API Key
    echo "$CONTENT" | grep -qE "sk-ant-[A-Za-z0-9_-]{20,}" && {
        echo "  BLOCKED: Anthropic API Key found in $file"
        FOUND=$((FOUND + 1))
    }

    # OpenAI API Key
    echo "$CONTENT" | grep -qE "sk-[A-Za-z0-9]{20,}" && {
        echo "  BLOCKED: OpenAI API Key found in $file"
        FOUND=$((FOUND + 1))
    }

    # Private Key
    echo "$CONTENT" | grep -qE "-----BEGIN .*(PRIVATE KEY|CERTIFICATE)-----" && {
        echo "  BLOCKED: Private Key/Certificate found in $file"
        FOUND=$((FOUND + 1))
    }

    # Connection String with password
    echo "$CONTENT" | grep -qiE "(Server|Data Source)=.*Password=" && {
        echo "  BLOCKED: Connection String with Password found in $file"
        FOUND=$((FOUND + 1))
    }

    # Hardcoded password/secret assignments
    echo "$CONTENT" | grep -qiE "(password|passwd|secret|token)[[:space:]]*[:=][[:space:]]*['\"][^'\"]{8,}['\"]" && {
        echo "  BLOCKED: Hardcoded secret assignment found in $file"
        FOUND=$((FOUND + 1))
    }

    # Bearer tokens
    echo "$CONTENT" | grep -qiE "bearer[[:space:]]+[A-Za-z0-9_./-]{20,}" && {
        echo "  BLOCKED: Bearer Token found in $file"
        FOUND=$((FOUND + 1))
    }

    # .env variable with key prefix
    echo "$CONTENT" | grep -qE "^[A-Z_]+=(sk-|ghp_|AKIA|Bearer )" && {
        echo "  BLOCKED: .env variable with secret prefix found in $file"
        FOUND=$((FOUND + 1))
    }
done

if [ $FOUND -gt 0 ]; then
    echo ""
    echo "COMMIT BLOCKED: Found $FOUND potential secret(s) in staged files."
    echo "  Fix: Remove secrets and use environment variables instead."
    echo "  Bypass (NOT recommended): git commit --no-verify"
    exit 1
fi

echo "OK: No secrets detected."
exit 0
