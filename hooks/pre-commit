#!/bin/sh
# ──────────────────────────────────────────────────────────────────
# Watchdog — Claude Code Supervisor Agent
# Author: Dennis "Shamunda" Ross
# Date:   March 2026
# MCP server that monitors and supervises Claude Code sessions.
# ──────────────────────────────────────────────────────────────────
# ── Watchdog pre-commit hook: Secret & Sensitive Data Scanner ──
# Blocks commits that contain API keys, tokens, passwords, private keys,
# connection strings, or other secrets.

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "🔒 Watchdog: Scanning staged files for secrets..."

# Get list of staged files (excludes deleted files)
STAGED=$(git diff --cached --name-only --diff-filter=d)

if [ -z "$STAGED" ]; then
    exit 0
fi

FOUND=0

# ── Pattern definitions ──
# Each pattern: "LABEL:::REGEX"
PATTERNS=(
    "AWS Access Key:::AKIA[0-9A-Z]{16}"
    "AWS Secret Key:::['\"]?[0-9a-zA-Z/+]{40}['\"]?"
    "GitHub Token:::gh[pousr]_[A-Za-z0-9_]{36,}"
    "Anthropic API Key:::sk-ant-[A-Za-z0-9_-]{20,}"
    "OpenAI API Key:::sk-[A-Za-z0-9]{20,}"
    "Generic API Key:::(?i)(api[_-]?key|apikey)\s*[:=]\s*['\"][A-Za-z0-9_\-]{16,}['\"]"
    "Generic Secret:::(?i)(secret|token|password|passwd|pwd)\s*[:=]\s*['\"][^\s'\"]{8,}['\"]"
    "Private Key:::-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"
    "Connection String:::(?i)(Server|Data Source)=.*Password="
    "Bearer Token:::(?i)bearer\s+[A-Za-z0-9\-._~+/]+=*"
    "Basic Auth:::(?i)basic\s+[A-Za-z0-9+/]{20,}={0,2}"
    "Hardcoded Password:::(?i)(password|passwd|pwd)\s*=\s*['\"][^'\"]{4,}['\"]"
    ".env Variable Leak:::(?i)^[A-Z_]+=(sk-|ghp_|AKIA|Bearer )"
)

# Files/paths to always skip
SKIP_PATTERNS="\.lock$|package-lock\.json$|\.min\.js$|\.min\.css$|\.dll$|\.exe$|\.png$|\.jpg$|\.gif$|\.ico$|\.woff"

for file in $STAGED; do
    # Skip binary/minified files
    echo "$file" | grep -qE "$SKIP_PATTERNS" && continue

    # Skip the hook files themselves
    echo "$file" | grep -qE "^hooks/pre-commit$|^hooks/pre-push$" && continue

    # Get staged content (not working directory)
    CONTENT=$(git show ":$file" 2>/dev/null) || continue

    for pattern_entry in "${PATTERNS[@]}"; do
        LABEL="${pattern_entry%%:::*}"
        REGEX="${pattern_entry##*:::}"

        MATCHES=$(echo "$CONTENT" | grep -nP "$REGEX" 2>/dev/null | head -5)
        if [ -n "$MATCHES" ]; then
            if [ $FOUND -eq 0 ]; then
                echo ""
                echo -e "${RED}╔══════════════════════════════════════════════════╗${NC}"
                echo -e "${RED}║  ⚠  SECRETS DETECTED — COMMIT BLOCKED           ║${NC}"
                echo -e "${RED}╚══════════════════════════════════════════════════╝${NC}"
            fi
            FOUND=$((FOUND + 1))
            echo ""
            echo -e "${YELLOW}── $LABEL in: $file${NC}"
            echo "$MATCHES" | while IFS= read -r line; do
                LINE_NUM=$(echo "$line" | cut -d: -f1)
                echo -e "   ${RED}Line $LINE_NUM${NC}"
            done
        fi
    done
done

if [ $FOUND -gt 0 ]; then
    echo ""
    echo -e "${RED}Found $FOUND potential secret(s) in staged files.${NC}"
    echo ""
    echo "  To fix: Remove the secrets, use environment variables instead."
    echo "  To bypass (NOT recommended): git commit --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ No secrets detected. Commit proceeding.${NC}"
exit 0
