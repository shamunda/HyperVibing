#!/bin/sh
# ──────────────────────────────────────────────────────────────────
# Watchdog — Claude Code Supervisor Agent
# Author: Dennis "Shamunda" Ross
# Date:   March 2026
# MCP server that monitors and supervises Claude Code sessions.
# ──────────────────────────────────────────────────────────────────
# ── Watchdog pre-push hook: Final safety gate before publishing ──
# Checks for sensitive file paths, large blobs, and secret patterns.
# Uses grep -E (POSIX extended regex) for cross-platform compatibility.

echo "Watchdog: Pre-push safety check..."

REMOTE="$1"
URL="$2"
FOUND=0

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        RANGE="$local_sha"
    else
        RANGE="$remote_sha..$local_sha"
    fi

    # ── Check 1: Sensitive file paths ──
    SENSITIVE_FILES=$(git diff --name-only "$RANGE" 2>/dev/null | grep -iE \
        "PrivateDocs/|\.env$|\.env\.|id_rsa|id_ed25519|\.pem$|\.key$|credentials|\.secret" \
        2>/dev/null)

    if [ -n "$SENSITIVE_FILES" ]; then
        FOUND=$((FOUND + 1))
        echo "  BLOCKED: Sensitive files found in push:"
        echo "$SENSITIVE_FILES" | while IFS= read -r f; do
            echo "    - $f"
        done
    fi

    # ── Check 2: Secret patterns in changed files ──
    CHANGED=$(git diff --name-only --diff-filter=d "$RANGE" 2>/dev/null)
    SKIP_PATTERNS="\.(lock|min\.js|dll|exe|png|jpg|gif)$"

    for file in $CHANGED; do
        echo "$file" | grep -qE "$SKIP_PATTERNS" && continue
        CONTENT=$(git show "$local_sha:$file" 2>/dev/null) || continue

        echo "$CONTENT" | grep -qE "AKIA[0-9A-Z]{16}" && {
            echo "  BLOCKED: AWS Access Key in $file"
            FOUND=$((FOUND + 1))
        }
        echo "$CONTENT" | grep -qE "gh[pousr]_[A-Za-z0-9_]{36,}" && {
            echo "  BLOCKED: GitHub Token in $file"
            FOUND=$((FOUND + 1))
        }
        echo "$CONTENT" | grep -qE "sk-ant-[A-Za-z0-9_-]{20,}" && {
            echo "  BLOCKED: Anthropic API Key in $file"
            FOUND=$((FOUND + 1))
        }
        echo "$CONTENT" | grep -qE "sk-[A-Za-z0-9]{20,}" && {
            echo "  BLOCKED: OpenAI API Key in $file"
            FOUND=$((FOUND + 1))
        }
        echo "$CONTENT" | grep -qE -- "-----BEGIN .*(PRIVATE KEY|CERTIFICATE)-----" && {
            echo "  BLOCKED: Private Key/Certificate in $file"
            FOUND=$((FOUND + 1))
        }
    done
done

if [ $FOUND -gt 0 ]; then
    echo ""
    echo "PUSH BLOCKED: Found $FOUND issue(s). Fix before pushing."
    echo "  Bypass (NOT recommended): git push --no-verify"
    exit 1
fi

echo "OK: Pre-push checks passed."
exit 0
