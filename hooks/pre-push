#!/bin/sh
# ── Watchdog pre-push hook: Final safety gate before publishing ──
# Runs the same secret scan as pre-commit, plus checks for:
#   - Accidental pushes of PrivateDocs content
#   - .env files
#   - Large binary blobs

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

echo "🔒 Watchdog: Pre-push safety check..."

REMOTE="$1"
URL="$2"
FOUND=0

while read local_ref local_sha remote_ref remote_sha; do
    if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
        # New branch — check all commits
        RANGE="$local_sha"
    else
        RANGE="$remote_sha..$local_sha"
    fi

    # ── Check 1: Sensitive file paths ──
    SENSITIVE_FILES=$(git diff --name-only "$RANGE" 2>/dev/null | grep -iE \
        "PrivateDocs/|\.env$|\.env\.|id_rsa|id_ed25519|\.pem$|\.key$|credentials|\.secret" \
        2>/dev/null)

    if [ -n "$SENSITIVE_FILES" ]; then
        if [ $FOUND -eq 0 ]; then
            echo ""
            echo -e "${RED}╔══════════════════════════════════════════════════╗${NC}"
            echo -e "${RED}║  ⚠  SENSITIVE FILES DETECTED — PUSH BLOCKED     ║${NC}"
            echo -e "${RED}╚══════════════════════════════════════════════════╝${NC}"
        fi
        FOUND=$((FOUND + 1))
        echo ""
        echo -e "${YELLOW}Sensitive files found in commits being pushed:${NC}"
        echo "$SENSITIVE_FILES" | while IFS= read -r f; do
            echo -e "   ${RED}$f${NC}"
        done
    fi

    # ── Check 2: Large files (>5MB) ──
    LARGE_FILES=$(git diff --name-only "$RANGE" 2>/dev/null | while read fname; do
        SIZE=$(git cat-file -s "$(git ls-tree -r "$local_sha" -- "$fname" 2>/dev/null | awk '{print $3}')" 2>/dev/null)
        if [ -n "$SIZE" ] && [ "$SIZE" -gt 5242880 ] 2>/dev/null; then
            echo "$fname ($(( SIZE / 1048576 ))MB)"
        fi
    done)

    if [ -n "$LARGE_FILES" ]; then
        FOUND=$((FOUND + 1))
        echo ""
        echo -e "${YELLOW}Large files (>5MB) detected:${NC}"
        echo "$LARGE_FILES" | while IFS= read -r f; do
            echo -e "   ${RED}$f${NC}"
        done
    fi

    # ── Check 3: Secret patterns in changed files ──
    CHANGED=$(git diff --name-only --diff-filter=d "$RANGE" 2>/dev/null)
    SKIP_PATTERNS="\.lock$|package-lock\.json$|\.min\.js$|\.dll$|\.exe$|\.png$|\.jpg$|\.gif$"

    SECRET_PATTERNS=(
        "AWS Access Key:::AKIA[0-9A-Z]{16}"
        "GitHub Token:::gh[pousr]_[A-Za-z0-9_]{36,}"
        "Anthropic API Key:::sk-ant-[A-Za-z0-9_-]{20,}"
        "OpenAI API Key:::sk-[A-Za-z0-9]{20,}"
        "Private Key:::-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----"
    )

    for file in $CHANGED; do
        echo "$file" | grep -qE "$SKIP_PATTERNS" && continue
        CONTENT=$(git show "$local_sha:$file" 2>/dev/null) || continue

        for pattern_entry in "${SECRET_PATTERNS[@]}"; do
            LABEL="${pattern_entry%%:::*}"
            REGEX="${pattern_entry##*:::}"
            if echo "$CONTENT" | grep -qP "$REGEX" 2>/dev/null; then
                FOUND=$((FOUND + 1))
                echo ""
                echo -e "${YELLOW}── $LABEL found in: $file${NC}"
            fi
        done
    done
done

if [ $FOUND -gt 0 ]; then
    echo ""
    echo -e "${RED}Push blocked. Fix the issues above before pushing.${NC}"
    echo "  To bypass (NOT recommended): git push --no-verify"
    echo ""
    exit 1
fi

echo -e "${GREEN}✓ Pre-push checks passed.${NC}"
exit 0
